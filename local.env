# Settings required to create a local database without SSL/TSL certifications used for the public database
COMPOSE_PROFILES=api,next,db
USE_EXTERNAL_NETWORK=false
DATABASE_TYPE=local
CLIENT_TLS=false
SSL_KEYS_VOLUME_EXTERNAL=false
MONGO_HOST=localhost
MONGO_BUILD_HOST=localhost
# Secrets to change
MONGO_USERNAME=username
MONGO_PASSWORD="your-50-character-or-more-password-here"
DJANGO_SECRT_KEY="your-100-character-or-more-secret-key-for-django-hash-table-configuration"
JUPYTER_TOKEN="your-50-character-or-more-token-for-jupyter-notebook"